{% extends 'cards/card_edit_center.html.twig' %}
{% from 'macros/_icons.html.twig' import link %}
{# parameters #}
{%- set title = 'security.login.title' -%}
{%- set title_description = 'security.login.description' -%}
{%- set title_icon = 'fa-solid fa-sign-in-alt' -%}
{%- set submit_text = 'security.login.submit' -%}
{%- set submit_title = 'security.login.title' -%}
{%- set cancel_path = false -%}
{# footer #}
{% block card_body -%}
    {{ parent() }}
    <input type="hidden" name="{{ constant('App\\Constants\\SecurityAttributes::LOGIN_TOKEN') }}"
           value="{{ csrf_token(constant('App\\Constants\\SecurityAttributes::AUTHENTICATE_TOKEN')) }}">
{% endblock card_body %}
{# actions #}
{% block actions_form %}
    {{ parent() }}
    {{ link(
        href: path('app_forgot_password_request'),
        text: 'resetting.link',
        class: 'btn btn-form btn-secondary',
        icon: 'fa-solid fa-circle-question',
        title: 'resetting.request.description',
        inline: true) }}
{% endblock actions_form %}
{# javascripts #}
{% block javascripts %}
    {% if is_js_debug %}
        {{ parent() }}
        {{ asset_js('js/extensions/password-extensions.js') }}
        {{ asset_js('js/application/user_recaptcha.js') }}
        {{ asset_js('js/application/user_login.js') }}
    {% else %}
        {{ asset_js('js/compiled/user_login.js') }}
    {%- endif %}
{% endblock javascripts %}
