{% extends 'cards/card_delete.html.twig' %}
{% from 'macros/_icons.html.twig' import button %}
{# parameters #}
{%- set title = 'clear_cache.title' -%}
{%- set submit_text = 'clear_cache.submit' -%}
{%- set message = 'clear_cache.message' %}
{%- set message_parameters = {'%size%': size} -%}
{% block card_container_class ' col-md-8 offset-md-2 col-xl-6 offset-xl-3' %}
{# body #}
{% block body -%}
    {{ parent() }}
    {{ include('admin/_cache_dialog.html.twig') }}
{% endblock body %}
{# actions #}
{% block actions_form -%}
    {{ parent() }}
    {{ button(
        text: 'clear_cache.list',
        class: 'btn btn-form btn-outline-info',
        icon: 'list-check',
        attributes: {
            'data-bs-toggle': 'modal',
            'data-bs-target': '#modal-cache-list',
        })
    }}
{% endblock actions_form %}
