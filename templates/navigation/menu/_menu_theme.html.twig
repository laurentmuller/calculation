{% set current = theme(app.request) %}
<li>
    <button class="dropdown-item theme-switcher rowlink-skip" role="button" title="{{ 'theme.help'|trans }}" data-url="{{ path('theme_dialog') }}">
        <i class="theme-icon {{ current.icon }}"></i><span class="theme-text ms-1">{{ current|trans }}</span>
    </button>
</li>
