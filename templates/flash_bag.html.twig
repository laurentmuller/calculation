{# attributes #}
{% set flash_attrs = {
    dataset: '#flashes',
    target: '.page-content',
    subtitle: app_full_name,
    'close-title': 'common.button_close'|trans} %}
{% if app.user %}
    {% set flash_attrs = flash_attrs|merge(user_parameters.message.attributes) %}
{% else %}
    {% set flash_attrs = flash_attrs|merge(application_parameters.message.attributes) %}
{% endif %}
{# add all flash messages #}
<div id="flashes" class="d-none" {{ html_data_attr(flash_attrs) }}>
    {% for key, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash" data-type="{{ key }}" data-title="{{ ('flash_bag.' ~ key)|trans }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
</div>
