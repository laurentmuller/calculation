{% extends 'cards/card_edit.html.twig' %}
{% from 'macros/_icons.html.twig' import icon, button, dropdownItemButton %}
{% form_theme form with _self %}
{# parameters #}
{%- set cancel_path = path('homepage') -%}
{%- set form_attr = form_attr|default({})|merge({'data-random': url('ajax_random_text'), 'data-failure': 'parameters.failure'|trans}) -%}
{% block card_body_class ' p-0' %}
{# custom progress widget #}
{% block _message_progress_widget -%}
    <div class="input-group">
        {{- block('choice_widget') -}}
        {{- button(
            text: null,
            class: 'btn btn-notify btn-outline-secondary d-print-none',
            icon: 'fa-regular fa-bell',
            inline: false,
            attributes: {title: 'parameters.action_test'|trans})
        -}}
        {{- button(
            text: null,
            class: 'btn btn-outline-secondary dropdown-toggle dropdown-toggle-split',
            attributes: {
                title: 'parameters.action_test'|trans,
                'data-bs-toggle': 'dropdown',
                'aria-expanded': false})
        -}}
        <ul class="dropdown-menu dropdown-menu-end">
            {% for type in enum_cases('App\\Enums\\FlashType') %}
                <li>
                    <button class="dropdown-item dropdown-notify" type="button" data-value="{{ type.value }}">
                        <i class="me-1 {{ type.icon }} {{ type.color }}"></i>{{- type|trans -}}
                    </button>
                </li>
            {% endfor %}
        </ul>
    </div>
{%- endblock _message_progress_widget %}
{# macros #}
{% macro renderHeader(href, icon, expanded = false) %}
    {%- set show = 'common.expand'|trans -%}
    {%- set hide = 'common.collapse'|trans -%}
    {%- set attrs = {
        href: '#' ~ href,
        class: ['drop-down-icon-right', 'card-title', expanded ? 'show' : null],
        title: expanded ? hide : show,
        'data-bs-toggle': 'collapse',
        'data-show': show,
        'data-hide': hide,
        'aria-expanded': expanded,
    } -%}
    <div class="card-header d-flex-wrap-center">
        <a {{ html_attr(attrs) }}>
            {{- icon(icon ~ ' fa-fw', 'parameters.group_' ~ href) -}}
        </a>
    </div>
{% endmacro renderHeader %}
{% macro renderDescription(key) %}
    <p class="my-2 form-text">{{ ('parameters.group_' ~ key ~ '_help')|trans }}</p>
{% endmacro renderDescription %}
{# form #}
{% block actions_form -%}
    {{ parent() }}
    <div class="dropdown">
        {%- set attrs = {
            type: 'button',
            class: ['btn', 'btn-form', 'btn-outline-success', 'dropdown-toggle'],
            title: 'parameters.default_help'|trans,
            'data-bs-toggle': 'dropdown',
            'aria-expanded': false,
        } -%}
        <button {{ html_attr(attrs) }}>
            {{- icon(icon: 'fa-solid fa-rotate-left', text: 'parameters.default', inline: true) -}}
        </button>
        <ul class="dropdown-menu">
            {{- dropdownItemButton(
                text: 'parameters.default_visible',
                icon: 'fa-solid fa-reply',
                class: 'btn-item-visible')
            -}}
            {{- dropdownItemButton(
                text: 'parameters.default_all',
                icon: 'fa-solid fa-reply-all',
                class: 'btn-item-all')
            -}}
        </ul>
    </div>
{%- endblock actions_form %}
{# javascripts #}
{% block javascripts %}
    {% if is_js_debug %}
        {{ parent() }}
        {{ asset_js('js/plugins/plugin-input-number.js') }}
        {{ asset_js('js/application/parameters_edit.js') }}
    {% else %}
        {{ asset_js('js/compiled/parameters_edit.js') }}
    {% endif %}
{% endblock javascripts %}
