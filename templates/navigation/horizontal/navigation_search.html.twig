{# search form #}
{% from 'macros/_icons.html.twig' import icon %}
{% set search_button_attrs = {
    id: 'search-button-horizontal',
    class: 'nav-link',
    title: 'search.title'|trans,
} %}
{% set search_div_attrs = {
    id: 'search-div-horizontal',
    class: ['my-auto', 'mx-lg-2', 'py-1 py-lg-0', 'd-none'],
    role: 'search',
} %}
{% set search_input_attrs = {
    type: 'text',
    id: 'search-input-horizontal',
    class: ['form-control', 'form-control-sm', 'w-100'],
    'aria-label': 'search.title'|trans,
    minlength: 2,
    autocomplete: 'off',
    required: 'required',
    placeholder: 'search.title'|trans,
    'data-action': path('search'),
    'data-display': false|json_encode,
    'data-bs-toggle': 'tooltip',
    'data-bs-trigger': 'manual',
    'data-bs-custom-class': 'tooltip-danger',
    'data-bs-title': 'search.minimum'|trans,
} %}
<li class="nav-item my-auto">
    <button {{ html_attr(search_button_attrs) }}>
        {{- icon('search fa-fw') -}}
    </button>
    <div {{ html_attr(search_div_attrs) }}>
        <input {{ html_attr(search_input_attrs) }}>
    </div>
</li>
