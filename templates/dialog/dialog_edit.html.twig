{# edit modal dialog #}
{% from 'macros/_icons.html.twig' import button, modal_close_button, icon %}
{# parameters #}
{%- set form_prefix = form_prefix|default('edit') -%}
{%- set dialog_icon = dialog_icon|default(ICON_EDIT) -%}
{%- set dialog_id = form_prefix ~ '_modal' -%}
{%- set add_title = add_title|default('common.button_add'|trans) -%}
{%- set edit_title = edit_title|default('common.button_edit'|trans) -%}
{%- set form_attr = form_attr|default({})|merge({
    id: form_prefix ~ '_form',
    autocomplete: 'off',
    'data-add': add_title,
    'data-edit': edit_title,
}) -%}
{# modal #}
<div class="modal fade" id="{{ dialog_id }}" tabindex="-1" aria-labelledby="{{ dialog_id }}" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form {{ html_attr(form_attr) }}>
                <div class="modal-header">
                    <h5 class="modal-title" id="{{ dialog_id }}">
                        {{- icon(dialog_icon ~ ' me-1') }}<span class="dialog-title">{{ edit_title }}</span>
                    </h5>
                    {{- modal_close_button(for_header: true, data_target: dialog_id) }}
                </div>
                <div class="modal-body">
                    {% block modal_body %}{% endblock modal_body %}
                </div>
                <div class="modal-footer justify-content-start">
                    <div class="d-flex-wrap justify-content-between w-100">
                        <div class="d-flex-wrap">
                            {{ button(
                                text: 'common.button_ok',
                                class: 'btn btn-form btn-primary',
                                icon: 'check',
                                type: 'submit',
                                attributes: {id: 'dialog_submit_button'})
                            }}
                            {{- modal_close_button(for_header: false, data_target: dialog_id) }}
                            {%- block modal_buttons -%}{%- endblock modal_buttons -%}
                        </div>
                        <small class="small-required">{{ 'common.required'|trans }}</small>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
