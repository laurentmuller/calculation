{% extends 'cards/card_edit_center.html.twig' %}
{% from 'macros/_icons.html.twig' import link %}
{# parameters #}
{%- set title = 'resetting.request.title' -%}
{%- set title_icon = 'eraser' -%}
{%- set submit_text = 'resetting.request.submit' -%}
{%- set submit_title = 'resetting.request.submit_title' -%}
{%- set cancel_path = false -%}
{%- set form_attr = form_attr|default({})|merge({'data-equal_to': 'password.mismatch'|trans([], 'validators')}) -%}
{# actions #}
{% block actions_form %}
    {{ parent() }}
    {{ link(
        href: path('app_login'),
        text: 'security.login.submit',
        class: 'btn btn-form btn-secondary',
        icon: 'sign-in-alt',
        title: 'security.login.description',
        inline: true) }}
{% endblock actions_form %}
{# javascripts #}
{% block javascripts %}
    {% if is_js_debug %}
        {{ parent() }}
        {{ asset_js('js/plugins/plugin-password-strength.js') }}
        {{ asset_js('js/extensions/password-extensions.js') }}
        {{ asset_js('js/application/user_recaptcha.js') }}
        {{ asset_js('js/application/user_reset.js') }}
    {% else %}
        {{ asset_js('js/compiled/user_reset.js') }}
    {% endif %}
{%- endblock javascripts %}
