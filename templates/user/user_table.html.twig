{% extends 'cards/card_table.html.twig' %}
{% from 'macros/_icons.html.twig' import link %}
{# parameters #}
{%- set title = 'user.list.title' -%}
{%- set title_icon = ICON_USER -%}
{%- set object_type = ENTITY_USER -%}
{%- set attributes = attributes|default({})|merge({'user-id': app.user.id}) -%}
{# header actions #}
{% block header_actions -%}
{% if allow_add %}
    {{ link(
        href: path('user_add', params),
        text: 'user.add.title',
        class: 'add-link p-0') }}
{% endif %}
{%- endblock header_actions %}
{# global actions #}
{% block global_actions -%}
{% if customData.resetPasswords %}
    {{- _self.item_path(path('user_reset_all', params), 'user.reset_all.title', ICON_DELETE) }}
    {{- _self.item_separator() }}
{% endif %}
{{- _self.item_external(path('user_pdf'), 'user.list.pdf_title', ICON_PDF) }}
{{- _self.item_external(path('user_excel'), 'user.list.excel_title', ICON_EXCEL) }}
{{- _self.item_separator() }}
{{- _self.item_external(path('user_rights_pdf'), 'user.list.rights_export', ICON_PDF) }}
{{- _self.item_external(path('user_rights_excel'), 'user.list.rights_excel', ICON_EXCEL) }}
{%- endblock global_actions %}
{# show actions #}
{% block show_actions -%}
{{- _self.item_path(path('user_show', params), 'user.show.title', ICON_SHOW, show_class) }}
{%- endblock show_actions %}
{# edit actions #}
{% block edit_actions -%}
{{- _self.item_path(path('user_edit', params), 'user.edit.title', ICON_EDIT, edit_class) }}
{{- _self.item_path(path('user_rights', params), 'user.rights.action', 'fa-solid fa-unlock', 'btn-rights') }}
{{- _self.item_path(path('user_password', params), 'user.change_password.title', 'fa-solid fa-unlock-alt', 'btn-password') }}
{%- endblock edit_actions %}
{# delete actions #}
{% block delete_actions -%}
{{- _self.item_path(path('user_delete', params), 'user.delete.title', ICON_DELETE, 'btn-delete btn-user-delete') }}
{%- endblock delete_actions %}
{# add actions #}
{% block add_actions -%}
{{- _self.item_path(path('user_add', params), 'user.add.title', ICON_ADD, 'btn-add') }}
{%- endblock add_actions %}
{# other actions #}
{% block other_actions -%}
{% if allow_edit %}
    {% if allow_edit or allow_delete or allow_add or allow_show %}
        {{- _self.item_separator('user-message-divider') }}
    {% endif %}
    {{- _self.item_path(path('user_message', params), 'user.message.title', 'fa-regular fa-envelope', 'btn-user-message') }}
    {{- _self.item_separator('user-reset-divider') }}
    {% if is_granted(ROLE_SUPER_ADMIN) %}
        {{- _self.item_path(path('user_reset_send', params), 'user.send.title', 'fa-solid fa-envelope-circle-check', 'btn-user-send') }}
    {% endif %}
    {{- _self.item_path(path('user_reset', params), 'user.reset.title', ICON_DELETE, 'btn-user-reset') }}
{% endif %}
{%- if not is_granted(IS_IMPERSONATOR) and is_granted(ROLE_SUPER_ADMIN) -%}
    {%- set param_name = constant('App\\Listener\\SwitchUserListener::SWITCH_USER_PARAMETER') -%}
    {{- _self.item_separator('user-switch-divider') }}
    {{- _self.item_path(path('homepage', {(param_name): '_username_'}), 'user.switch.take.title', 'fa-solid fa-user-plus', 'btn-user-switch btn-skip-href') }}
{%- endif -%}
{%- endblock other_actions %}
{# custom view header #}
{% block custom_view_header -%}
{%- if row_edit -%}
    <a href="{{ path('user_edit', params) }}" class="item-link text-body d-flex" title="{{ 'user.edit.title'|trans }}">
        %imageName%<span class="align-top">%username%</span>
    </a>
{%- elseif row_show -%}
    <a href="{{ path('user_show', params) }}" class="item-link text-body d-flex" title="{{ 'user.show.title'|trans }}">
        %imageName%<span class="align-top">%username%</span>
    </a>
{%- else -%}
    %imageName%<span class="align-top">%username%</span>
{%- endif -%}
{%- endblock custom_view_header %}
{# custom view body #}
{% block custom_view_body -%}
{{ _self.property_row('user.fields.email', '%email%') }}
{{ _self.property_row('user.fields.role', '%role%') }}
{{ _self.property_row('user.fields.enabled', '%enabled%') }}
{{ _self.property_row('user.fields.lastLogin', '%lastLogin%') }}
{%- endblock custom_view_body %}
{# body #}
{% block body %}
{{ parent() }}
{{ include('user/user_switch.html.twig') }}
{% endblock body %}
