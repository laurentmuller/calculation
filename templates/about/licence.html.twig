{% extends 'cards/card_base.html.twig' %}
{% from 'macros/_icons.html.twig' import link, homepage, sitemap, button_pdf, button_word %}
{# parameters #}
{%- set title = 'about.licence.title' -%}
{%- set title_icon = 'info-circle' -%}
{%- set accepted = app.request.cookies.boolean(constant('App\\Controller\\PolicyController::POLICY_ACCEPTED')) -%}
{%- set is_remembered = is_granted(IS_AUTHENTICATED_REMEMBERED) -%}
{# navigation #}
{% block card_container_class is_remembered ? '' : ' mt-3' %}
{% block navigation_horizontal -%}{% if is_remembered %}{{ parent() }}{% endif %}{%- endblock navigation_horizontal %}
{% block navigation_vertical -%}{% if is_remembered %}{{ parent() }}{% endif %}{%- endblock navigation_vertical %}
{% block cookie_banner -%}{% endblock cookie_banner %}
{# body #}
{% block card_body %}
    {{ content|raw }}
{% endblock card_body %}
{# footer #}
{% block card_footer %}
<div class="d-flex-wrap">
    {% if is_remembered %}
        {{ homepage() }}
        {% if not accepted %}
            {{ link(
                href: path('policy_accept'),
                text: 'cookie_banner.accept',
                class: 'btn btn-form btn-success',
                icon: 'check',
                title: 'cookie_banner.accept_title',
                inline: true) }}
        {% endif %}
    {% else %}
        {{ link(
            href: path('app_login'),
            text: 'index.login',
            class: 'btn btn-form btn-outline-primary',
            icon: 'sign-in-alt',
            inline: true) }}
    {% endif %}
    {{ sitemap() }}
    {% set caller = app.request.query.string('caller') %}
    {% set params = caller ? {caller: caller} : {} %}
    {{ link(
        href: path('about_policy_index', params),
        text: 'about.policy.title',
        class: 'btn btn-form btn-secondary',
        icon: 'info-circle',
        inline: true)
    }}
    {{ button_pdf('about_licence_pdf') }}
    {{ button_word('about_licence_word') }}
</div>
{% endblock card_footer %}
