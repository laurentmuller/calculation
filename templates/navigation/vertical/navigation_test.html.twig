{# admin menu #}
{% from 'macros/_icons.html.twig' import icon, dropdownSeparator, dropdownItem, dropdownItemExternal %}
{% set id = 'MENU_SIDEBAR_TEST' %}
{% set expanded = app.request.cookies.boolean(id) %}
{% set toggle_class = expanded ? ' active' : '' %}
{% set collapse_class = expanded ? ' show' : '' %}
{% set toggle_title = expanded ? 'index.menu_hide' : 'index.menu_show' %}
<li>{{ dropdownSeparator() }}</li>
<li class="nav-item nav-item-dropdown">
    <button class="nav-link nav-link-toggle{{ toggle_class }}" data-bs-toggle="collapse" data-bs-target="#{{ id }}" aria-expanded="{{ expanded|json_encode }}" title="{{ toggle_title|trans }}">
        {{- icon('fa-solid fa-bug fa-fw', 'index.menu_test') -}}
    </button>
    <div class="collapse{{ collapse_class }}" id="{{ id }}">
        <ul class="dropdown-menu d-block border-0 pt-0">
            {% set id = 'MENU_SIDEBAR_TEST_SERVICE' %}
            {% set expanded = app.request.cookies.boolean(id) %}
            {% set toggle_class = expanded ? ' active' : '' %}
            {% set collapse_class = expanded ? ' show' : '' %}
            {% set toggle_title = expanded ? 'index.menu_hide' : 'index.menu_show' %}
            <li class="nav-item nav-item-dropdown">
                <button class="nav-link nav-link-toggle{{ toggle_class }}" data-bs-toggle="collapse" data-bs-target="#{{ id }}" aria-expanded="{{ expanded|json_encode }}" title="{{ toggle_title|trans }}">
                    {{- icon('fa-solid fa-bell-concierge fa-fw', 'index.menu_service') -}}
                </button>
                <div class="collapse{{ collapse_class }}" id="{{ id }}">
                    <ul class="dropdown-menu d-block border-0 pt-0">
                        {{ dropdownItem(path('openweather_weather'), 'openweather.current.title', 'fa-solid fa-cloud-sun') }}
                        {{ dropdownItem(path('exchange_display'), 'exchange_rate.title', 'fa-solid fa-comments-dollar') }}
                        {{ dropdownItem(path('test_translate'), 'translator.title', 'fa-solid fa-globe') }}
                        {{ dropdownItem(path('ipstack'), 'test.ip_stack', 'fa-solid fa-location-dot') }}
                    </ul>
                </div>
            </li>

            {% set id = 'MENU_SIDEBAR_TEST_PAGE' %}
            {% set expanded = app.request.cookies.boolean(id) %}
            {% set toggle_class = expanded ? ' active' : '' %}
            {% set collapse_class = expanded ? ' show' : '' %}
            {% set toggle_title = expanded ? 'index.menu_hide' : 'index.menu_show' %}
            <li class="nav-item nav-item-dropdown">
                <button class="nav-link nav-link-toggle{{ toggle_class }}" data-bs-toggle="collapse" data-bs-target="#{{ id }}" aria-expanded="{{ expanded|json_encode }}" title="{{ toggle_title|trans }}">
                    {{- icon('fa-solid fa-bug fa-fw', 'index.menu_tools') -}}
                </button>
                <div class="collapse{{ collapse_class }}" id="{{ id }}">
                    <ul class="dropdown-menu d-block border-0 pt-0">
                        {{ dropdownItemExternal(path('test_fontawesome'), 'test.fontawesome', 'fa-regular fa-font-awesome') }}
                        {{ dropdownItemExternal(path('test_pdf'), 'common.button_pdf', ICON_PDF) }}
                        {{ dropdownItemExternal(path('test_word'), 'common.button_export', ICON_WORD) }}
                        {{ dropdownItem(path('test_tree'), 'test.tree_view', 'fa-solid fa-folder-tree') }}
                    </ul>
                </div>
            </li>

            {% set id = 'MENU_SIDEBAR_TEST_ADMIN' %}
            {% set expanded = app.request.cookies.boolean(id) %}
            {% set toggle_class = expanded ? ' active' : '' %}
            {% set collapse_class = expanded ? ' show' : '' %}
            {% set toggle_title = expanded ? 'index.menu_hide' : 'index.menu_show' %}
            <li class="nav-item nav-item-dropdown">
                <button class="nav-link nav-link-toggle{{ toggle_class }}" data-bs-toggle="collapse" data-bs-target="#{{ id }}" aria-expanded="{{ expanded|json_encode }}" title="{{ toggle_title|trans }}">
                    {{- icon('fa-solid fa-bug fa-fw', 'index.menu_admin') -}}
                </button>
                <div class="collapse{{ collapse_class }}" id="{{ id }}">
                    <ul class="dropdown-menu d-block border-0 pt-0">
                        {{ dropdownItem(path('schema_index'), 'schema.index.title', 'fa-solid fa-table') }}
                        {{ dropdownItem(path('diagram_index'), 'diagram.title', 'fa-solid fa-diagram-project') }}
                        {{ dropdownSeparator() }}
                        {{ dropdownItem(path('command_index'), 'command.list.title', 'fa-solid fa-code') }}
                        {{ dropdownSeparator() }}
                        {{ dropdownItem(path('admin_dump_sql'), 'admin.dump_sql.title', 'fa-solid fa-database') }}
                        {{ dropdownItem(path('admin_import'), 'swisspost.title', 'fa-solid fa-download') }}
                        {{ dropdownItem(path('generate'), 'generate.title', 'fa-solid fa-random') }}
                    </ul>
                </div>
            </li>

            {% set id = 'MENU_SIDEBAR_TEST_CHART' %}
            {% set expanded = app.request.cookies.boolean(id) %}
            {% set toggle_class = expanded ? ' active' : '' %}
            {% set collapse_class = expanded ? ' show' : '' %}
            {% set toggle_title = expanded ? 'index.menu_hide' : 'index.menu_show' %}
            <li class="nav-item nav-item-dropdown">
                <button class="nav-link nav-link-toggle{{ toggle_class }}" data-bs-toggle="collapse" data-bs-target="#{{ id }}" aria-expanded="{{ expanded|json_encode }}" title="{{ toggle_title|trans }}">
                    {{- icon('fa-solid fa-chart-area fa-fw', 'index.menu_graphics') -}}
                </button>
                <div class="collapse{{ collapse_class }}" id="{{ id }}">
                    <ul class="dropdown-menu d-block border-0 pt-0">
                        {{ dropdownItem(path('calculation_pivot_index'), 'pivot.title', 'fa-solid fa-table') }}
                        {{ dropdownItem(path('timeline_index'), 'timeline.title', 'fa-solid fa-stream') }}
                        {{ dropdownItem(path('calendar_year'), 'calendar.year_title', 'fa-regular fa-calendar-alt', {'%year%': 'now'|date('Y')}) }}
                    </ul>
                </div>
            </li>

            <li>{{ dropdownSeparator() }}</li>
            {{ dropdownItem(path('test_notifications'), 'test.notification', 'fa-regular fa-bell') }}
            {{ dropdownItem(path('test_editor'), 'test.editor', 'fa-solid fa-edit') }}
            {{ dropdownItem(path('test_password'), 'password.title', 'fa-solid fa-lock') }}
            {{ dropdownItem(path('test_recaptcha'), 'test.recaptcha', 'fa-brands fa-google') }}
            {{ dropdownItem(path('customer_index'), 'customer.list.title', ICON_CUSTOMER) }}
        </ul>
    </div>
</li>
