{# macros #}
{% macro card(id, title, pdf_route, excel_route = false, word_route = false) -%}
    {% from 'macros/_icons.html.twig' import link_pdf, link_word, link_excel %}
    <div class="card-header d-flex-wrap-center">
        <a class="drop-down-icon-left card-title flex-fill" href="#{{ id }}" data-bs-toggle="collapse" aria-expanded="false" title="{{ 'common.expand'|trans }}">
            {{- title|trans -}}
        </a>
        {{ link_pdf(pdf_route, 'fa-fw') }}
        {% if excel_route %}
            {{ link_excel(excel_route, 'fa-fw') }}
        {% endif %}
        {% if word_route %}
            {{ link_word(word_route, 'fa-fw') }}
        {% endif %}
    </div>
    <div class="card-body collapse" id="{{ id }}" data-bs-parent="#aboutAccordion">
        <div class="collapse-content" data-url="{{ path('about_' ~ id ~ '_content') }}">
            <div class="alert py-0 mb-0" role="alert">
                <span class="spinner-border spinner-border-sm me-2" role="status"></span><span>{{ 'about.load.message'|trans }}</span>
            </div>
        </div>
    </div>
{%- endmacro card %}

{% macro headerInfo(name) -%}
    <tr class="h">
        <th class="fw-bold" colspan="2">{{ name }}</th>
    </tr>
{%- endmacro headerInfo %}

{% macro rowInfo(name, value, name_class = '', value_class = '') -%}
    {%- set name_class = ('e ' ~ name_class|default(''))|trim -%}
    {%- set value_class = ('v ' ~ value_class|default(''))|trim -%}
    <tr>
        <td class="{{ name_class }}">{{ name }}</td>
        <td class="{{ value_class }}">{{- value -}}</td>
    </tr>
{%- endmacro rowInfo %}

{% macro rowInfoLink(name, value, href, name_class = '', value_class = '') -%}
    {%- set name_class = ('e ' ~ name_class|default(''))|trim -%}
    {%- set value_class = ('v ' ~ value_class|default(''))|trim -%}
    <tr>
        <td class="{{ name_class }}">{{ name }}</td>
        <td class="{{ value_class }}">
            <a href="{{ href }}" class="card-link" target="_blank" rel="noopener noreferrer">
                {{- value -}}
            </a>
        </td>
    </tr>
{%- endmacro rowInfoLink %}

{% macro rowInfoBoolean(name, value, enabled) -%}
    {%- if value === true or value === false -%}
        {%- set enabled = value -%}
        {%- set value = value|boolean -%}
    {%- endif -%}
    {%- set class = enabled ? 'enabled' : 'disabled' -%}
    <tr>
        <td class="e">{{ name }}</td>
        <td class="v {{ class }}">{{ value }}</td>
    </tr>
{%- endmacro rowInfoBoolean %}

{% macro headerLink(url, version, icon) -%}
    <div class="border-bottom pb-1">
        <a href="https://{{ url }}" target="_blank" rel="noopener noreferrer" title="{{ 'about.link_homepage'|trans }}" class="h1 d-flex flex-column">
            {{- source('about/' ~ icon ~ '.svg') }}
            <span>{{ 'about.version'|trans({'%version%': version}) -}}</span>
        </a>
    </div>
{%- endmacro headerLink %}
